# Runtime
NODE_ENV=production
PORT=4000
CLIENT_URL=https://your-domain.com
API_BASE_URL=https://your-domain.com
FRONTEND_DIST_DIR=../dist

# Database
# For Supabase on Render/Hostinger, use the Supavisor Session pooler URL, not the direct db.* host.
DATABASE_URL=postgresql://postgres.project-ref:password@region.pooler.supabase.com:5432/postgres

# Redis is optional. Leave empty to run without cache-backed features.
REDIS_URL=

# JWT secrets. Use long random values in production.
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_EMAIL_SECRET=change-me-email
JWT_PASSWORD_RESET_SECRET=change-me-password-reset

# Optional providers
TURNSTILE_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Iwosan <no-reply@iwosan.com>
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MONEROO_API_KEY=
MONEROO_SECRET_KEY=
MONEROO_WEBHOOK_SECRET=
MONEROO_BASE_URL=https://api.moneroo.io
