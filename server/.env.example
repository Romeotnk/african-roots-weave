# Runtime
NODE_ENV=production
PORT=4000
CLIENT_URL=https://your-domain.com
API_BASE_URL=https://your-domain.com
FRONTEND_DIST_DIR=../dist

# Database
# If your provider has no separate direct URL, set DIRECT_URL to the same value as DATABASE_URL.
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public
DIRECT_URL=postgresql://user:password@host:5432/database?schema=public

# Redis is optional. Leave empty to run without cache-backed features.
REDIS_URL=

# JWT secrets. Use long random values in production.
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_EMAIL_SECRET=change-me-email
JWT_PASSWORD_RESET_SECRET=change-me-password-reset

# Optional providers
TURNSTILE_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Iwosan <no-reply@iwosan.com>
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MONEROO_API_KEY=
MONEROO_SECRET_KEY=
MONEROO_WEBHOOK_SECRET=
MONEROO_BASE_URL=https://api.moneroo.io
